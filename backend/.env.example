# Guardian AI — environment template. Copy to .env and fill in.
# DO NOT put real secrets in this file — it is committed to source control.

# --- Azure OpenAI (used if AZURE_OPENAI_ENDPOINT is set) ---
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- OpenAI (used if Azure not configured) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Convergence
GUARDIAN_MAX_ITERATIONS=1
GUARDIAN_BLOCK_ON=HARD   # HARD only blocks approval; set to ALL to also block on SOFT

# CORS
GUARDIAN_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
